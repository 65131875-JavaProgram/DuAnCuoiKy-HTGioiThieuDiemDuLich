<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ImageView
        android:id="@+id/imgChiTiet"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:scaleType="centerCrop"
        android:src="@drawable/paris" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@android:color/transparent" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="35dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="25dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <RatingBar
                            android:id="@+id/ratingBarHienThi"
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:numStars="5"
                            android:rating="5"
                            android:progressTint="#FFD700" />
                        <TextView
                            android:id="@+id/txtSoSaoNhanXet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="6dp"
                            android:text="5.0 (147)"
                            android:textColor="#8E8E8E"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/txtTenChiTiet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paris"
                            android:textColor="#1E2333"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:orientation="vertical"
                            android:gravity="end">
                            <TextView
                                android:id="@+id/txtGiaChiTiet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$1240"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="#1E2333"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Per person"
                                android:textColor="@color/black"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@android:drawable/ic_menu_compass"
                            app:tint="#A0A0A0"/>

                        <TextView
                            android:id="@+id/txtQuocGiaChiTiet"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="4dp"
                            android:text="Phap"
                            android:textColor="@color/black"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="30dp"
                        android:layout_marginBottom="20dp"
                        android:weightSum="4">

                        <LinearLayout
                            android:id="@+id/btnTabOverview"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/txtTabOverview"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Overview"
                                android:textStyle="bold"
                                android:textColor="#1E2333"
                                android:textSize="14sp"/>
                            <View
                                android:id="@+id/indicatorOverview"
                                android:layout_width="5dp"
                                android:layout_height="5dp"
                                android:layout_marginTop="4dp"
                                android:background="#1E2333" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtTabPhotos"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Photos"
                            android:gravity="center"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/txtTabDetails"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Details"
                            android:gravity="center"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/txtTabReviews"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reviews"
                            android:gravity="center"
                            android:textColor="#A0A0A0"
                            android:textSize="14sp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutOverviewContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="20dp"
                            android:weightSum="3">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp"
                                android:background="#F5F6F8">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Duration"
                                    android:textColor="#A0A0A0"
                                    android:textSize="12sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5 Days"
                                    android:textColor="#1E2333"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp"
                                android:layout_marginLeft="10dp"
                                android:layout_marginRight="10dp"
                                android:background="#F5F6F8">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Weather"
                                    android:textColor="#A0A0A0"
                                    android:textSize="12sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="22°C"
                                    android:textColor="#1E2333"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="10dp"
                                android:background="#F5F6F8">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Guide"
                                    android:textColor="#A0A0A0"
                                    android:textSize="12sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="English"
                                    android:textColor="#1E2333"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtMoTaChiTiet"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nội dung mô tả chi tiết chuyến đi..."
                            android:textSize="15sp"
                            android:textColor="#5E6373"
                            android:lineSpacingExtra="6dp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnSelectDays"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="35dp"
                        android:layout_marginBottom="20dp"
                        android:backgroundTint="#2B2E43"
                        android:text="Select Days"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="29dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">
        <androidx.cardview.widget.CardView
            android:id="@+id/btnBackCard"
            android:layout_width="38dp"
            android:layout_height="38dp"
            app:cardCornerRadius="19dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardElevation="5dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#2B2E43"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_alignParentRight="true"
            app:cardCornerRadius="19dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardElevation="5dp">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_share"
                app:tint="#2B2E43"/>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/btnFavoriteCard"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_alignParentRight="true"
        android:layout_marginTop="273dp"
        android:layout_marginRight="30dp"
        app:cardCornerRadius="27dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@android:color/white">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@android:drawable/btn_star_big_on"
            app:tint="#2B2E43"/>
    </androidx.cardview.widget.CardView>

</RelativeLayout>